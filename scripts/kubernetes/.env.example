# ============================================================
# Kubernetes HA Cluster - shell-only deploy environment
# Copy this file to .env and edit values for your environment.
# ============================================================

IS_ORBSTACK="false"

SSH_USER="ubuntu"
SSH_KEY="~/.ssh/rha6780.pem"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10"

HAPROXY_IP="192.168.0.50"

CP_MASTER_IP="192.168.0.51"
CP_JOIN_IPS=(
  "192.168.0.52"
)

WORKER_IPS=(
  "192.168.0.61"
  "192.168.0.62"
)

CLUSTER_NAME="my-cluster"
CONTROL_PLANE_ENDPOINT="api.k8s.rha6780.com:6445"
POD_SUBNET="10.219.0.0/16"
SERVICE_SUBNET="10.96.0.0/12"

METALLB_IP_RANGE="192.168.0.34-192.168.0.39"

LB_FRONTEND_PORT=6445
K8S_API_PORT=6443
STATS_PORT=8080
STATS_USER="admin"
STATS_PASS="changeme"
RELEASE_CONFLICTING_PORTS="true" # haproxy에 이미 사용중인 포트가 있을 경우, haproxy를 재시작할 때 충돌이 발생합니다. true로 설정하면 haproxy를 재시작하기 전에 충돌하는 포트를 해제합니다.

CONTAINERD_VERSION="1.7.29-1~ubuntu.24.04~noble"
ALLOW_CONTAINERD_DOWNGRADE="false"
K8S_VERSION="1.36.2"
HELM_VERSION="3.21.2"
HAPROXY_VERSION="2.8.*"

CALICO_CHART_VERSION="3.32.0"
METALLB_CHART_VERSION="0.16.1"
GATEWAY_API_VERSION="1.5.1"
NGF_CHART_VERSION="2.6.5"
